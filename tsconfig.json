{
    "compilerOptions": {
        "target": "esnext",
        "module": "nodenext",
        "rootDir": "src",
        "outDir": "dist",
        "esModuleInterop": true,
        "strict": true,
        "declaration": true,
        "moduleResolution": "nodenext",
        "types": ["node", "vitest/globals"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
